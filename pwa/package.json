  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:app && pnpm run build:server && pnpm run build:sw",
    "build:app": "vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "build:sw": "tsx scripts/generate-sw.ts",
    "gcp-build": "",
    "dev": "vite dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "start": "cross-env NODE_ENV=production node ./server.js",
    "typecheck": "tsc && tsc --project tsconfig.server.json",
    "bundle-visualizer": "npx vite-bundle-visualizer",
    "test": "vitest ./app --coverage",
    "openapi-ts": "openapi-ts",
    "playwright": "playwright test"
  },
